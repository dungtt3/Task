{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "auth_db"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DefaultExpirationSeconds": 300
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32BytesLong!2024",
    "Issuer": "TaskManager",
    "Audience": "TaskManagerApp",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
